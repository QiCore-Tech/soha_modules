{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1",
    { "soha": "https://soha.ai/vocab/v1", "saref": "https://saref.etsi.org/core/" }
  ],
  "@type": "tm:ThingModel",
  "title": "LED Driver Module",
  "description": "WS2812/RGB LED strip driver. Controls 1-2 meter strips with per-pixel color, built-in effects, and brightness control.",
  "soha:moduleType": "peripheral",
  "soha:moduleName": "soha_led_v1",

  "soha:physics": { "joint": { "type": "fixed" } },

  "properties": {
    "status": {
      "type": "object", "readOnly": true, "observable": true,
      "properties": {
        "led_count":      { "type": "integer",                   "description": "Detected LEDs on strip" },
        "brightness":     { "type": "number", "unit": "percent", "description": "Global brightness" },
        "current_effect": { "type": "string",                    "description": "Running effect or 'none'" },
        "error":          { "type": "integer",                   "description": "Error code. 0 = normal" },
        "ready":          { "type": "boolean",                   "description": "Module initialized and ready" }
      },
      "forms": [{ "href": "/properties/status", "op": ["readproperty"] }]
    }
  },

  "actions": {
    "setColor": {
      "title": "Set all LEDs", "description": "Set every LED to same RGB color. Overrides effects.",
      "safe": false, "idempotent": true,
      "input": { "type": "object", "properties": { "r": { "type": "integer", "minimum": 0, "maximum": 255 }, "g": { "type": "integer", "minimum": 0, "maximum": 255 }, "b": { "type": "integer", "minimum": 0, "maximum": 255 } }, "required": ["r", "g", "b"] },
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/setColor", "op": ["invokeaction"] }]
    },
    "setPixel": {
      "title": "Set single LED", "description": "Set LED by index (0=closest to module).",
      "safe": false, "idempotent": false,
      "input": { "type": "object", "properties": { "index": { "type": "integer", "minimum": 0 }, "r": { "type": "integer", "minimum": 0, "maximum": 255 }, "g": { "type": "integer", "minimum": 0, "maximum": 255 }, "b": { "type": "integer", "minimum": 0, "maximum": 255 } }, "required": ["index", "r", "g", "b"] },
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/setPixel", "op": ["invokeaction"] }]
    },
    "setEffect": {
      "title": "Play LED effect", "description": "Built-in animation. Loops until next command. rainbow ignores color; others use r/g/b as base color.",
      "safe": false, "idempotent": true,
      "input": { "type": "object", "properties": { "name": { "type": "string", "enum": ["rainbow", "breathing", "chase", "blink", "gradient"] }, "speed": { "type": "number", "unit": "percent", "minimum": 0.1, "maximum": 1.0, "default": 0.5 }, "r": { "type": "integer", "minimum": 0, "maximum": 255, "default": 255 }, "g": { "type": "integer", "minimum": 0, "maximum": 255, "default": 255 }, "b": { "type": "integer", "minimum": 0, "maximum": 255, "default": 255 } }, "required": ["name"] },
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/setEffect", "op": ["invokeaction"] }]
    },
    "setBrightness": {
      "title": "Set brightness", "description": "Global brightness multiplier. 0=off, 1.0=max.",
      "safe": true, "idempotent": true,
      "input": { "type": "object", "properties": { "level": { "type": "number", "unit": "percent", "minimum": 0.0, "maximum": 1.0 } }, "required": ["level"] },
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/setBrightness", "op": ["invokeaction"] }]
    },
    "clear": {
      "title": "Turn off LEDs", "description": "All LEDs off. Stops effects.",
      "safe": true, "idempotent": true,
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/clear", "op": ["invokeaction"] }]
    }
  }
}
