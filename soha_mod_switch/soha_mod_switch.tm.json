{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1",
    { "soha": "https://soha.ai/vocab/v1", "saref": "https://saref.etsi.org/core/" }
  ],
  "@type": "tm:ThingModel",
  "title": "Switch Hub",
  "description": "4-port communication hub for star topology expansion. Provides signal conditioning for longer cable runs.",
  "soha:moduleType": "peripheral",

  "soha:physics": { "joint": { "type": "fixed" } },

  "properties": {
    "status": {
      "type": "object", "readOnly": true, "observable": true,
      "properties": {
        "port_count":      { "type": "integer",                  "description": "Total port count (4)" },
        "connected_ports": { "type": "array", "items": { "type": "boolean" }, "description": "Per-port connection status" },
        "error":           { "type": "integer",                  "description": "Error code. 0 = normal" },
        "ready":           { "type": "boolean",                  "description": "Module initialized and ready" }
      },
      "forms": [{ "href": "/properties/status", "op": ["readproperty"] }]
    }
  },

  "actions": {
    "reset": {
      "title": "Reset switch",
      "description": "Restart switch. Connected ports briefly disconnect during reset.",
      "safe": true, "idempotent": true,
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/reset", "op": ["invokeaction"] }]
    }
  },

  "events": {
    "portChanged": {
      "title": "Port connection changed",
      "data": {
        "type": "object",
        "properties": {
          "port":      { "type": "integer", "minimum": 0, "maximum": 3 },
          "connected": { "type": "boolean" },
          "timestamp": { "type": "integer", "unit": "ms" }
        }
      },
      "forms": [{ "href": "/events/portChanged", "op": ["subscribeevent"] }]
    }
  }
}
