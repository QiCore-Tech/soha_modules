{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1",
    { "soha": "https://soha.ai/vocab/v1", "saref": "https://saref.etsi.org/core/" }
  ],
  "@type": "tm:ThingModel",
  "title": "Battery Module",
  "description": "Smart battery with 24V bus output, USB-C PD charging, and SOC reporting. System power center hosting ESP32 main controller.",
  "soha:moduleType": "peripheral",
  "soha:moduleName": "soha_battery_v1",

  "soha:physics": { "joint": { "type": "fixed" } },

  "properties": {
    "status": {
      "type": "object", "readOnly": true, "observable": true,
      "properties": {
        "soc":         { "type": "number",  "unit": "percent",  "description": "State of charge (0-100%)" },
        "voltage":     { "type": "number",  "unit": "V",        "description": "Current battery voltage" },
        "current":     { "type": "number",  "unit": "A",        "description": "Current draw. Positive=discharging" },
        "temperature": { "type": "number",  "unit": "celsius",  "description": "Battery cell temperature" },
        "charging":    { "type": "boolean",                      "description": "USB-C PD actively charging" },
        "output_on":   { "type": "boolean",                      "description": "24V bus output enabled" },
        "capacity":    { "type": "number",  "unit": "mAh",      "description": "Battery total capacity" },
        "error":       { "type": "integer",                      "description": "Error code. 0 = normal" },
        "ready":       { "type": "boolean",                      "description": "Module initialized and ready" }
      },
      "forms": [{ "href": "/properties/status", "op": ["readproperty"] }]
    }
  },

  "actions": {
    "setOutput": {
      "title": "Control power output",
      "description": "Enable/disable 24V bus power to all modules.",
      "safe": false, "idempotent": true,
      "input": {
        "type": "object",
        "properties": { "enable": { "type": "boolean", "description": "true=on, false=off" } },
        "required": ["enable"]
      },
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/setOutput", "op": ["invokeaction"] }]
    },
    "emergencyCutoff": {
      "title": "Emergency power cutoff",
      "description": "Immediately cut all power. For electrical emergencies.",
      "safe": true, "idempotent": true,
      "output": { "type": "object", "properties": { "success": { "type": "boolean" } }, "required": ["success"] },
      "forms": [{ "href": "/actions/emergencyCutoff", "op": ["invokeaction"] }]
    }
  },

  "events": {
    "lowBattery": {
      "title": "Low battery warning",
      "description": "SOC below critical threshold.",
      "data": {
        "type": "object",
        "properties": {
          "soc": { "type": "number", "unit": "percent" },
          "timestamp": { "type": "integer", "unit": "ms" }
        }
      },
      "forms": [{ "href": "/events/lowBattery", "op": ["subscribeevent"] }]
    },
    "overTemperature": {
      "title": "Battery over-temperature warning",
      "description": "Cell temperature exceeds safe operating range.",
      "data": {
        "type": "object",
        "properties": {
          "temperature": { "type": "number", "unit": "celsius" },
          "timestamp":   { "type": "integer", "unit": "ms" }
        }
      },
      "forms": [{ "href": "/events/overTemperature", "op": ["subscribeevent"] }]
    }
  }
}
